# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Never expose to the client. Used by the sync/scoring engine.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API-Football (https://www.api-football.com/ -> dashboard)
API_FOOTBALL_KEY=your-api-football-key
# 2026 World Cup league id in API-Football (verify in dashboard)
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026

# Secret to protect the /api/sync cron endpoint
SYNC_SECRET=generate-a-long-random-string
